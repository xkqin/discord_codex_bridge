# Discord bot token from https://discord.com/developers/applications
# Never commit your real token.
DISCORD_BOT_TOKEN=

# Optional safety allow-list. Use comma-separated numeric Discord IDs.
# Leave DISCORD_ALLOWED_USER_IDS empty if the channel is private and trusted.
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_ALLOWED_USER_IDS=

# Bot trigger. Users can also mention the bot directly.
DISCORD_CODEX_PREFIX=!codex
DISCORD_CODEX_ACCEPT_ALL=0
DISCORD_MAX_REPLY_CHARS=1800

# Codex target. Prefer a fixed session id for predictable behavior.
CODEX_TARGET_SESSION_ID=
CODEX_USE_LAST=1
CODEX_WORKDIR=
CODEX_MODEL=
CODEX_TIMEOUT_SECONDS=900

# Leave this off unless you intentionally want Discord users to be able to ask
# Codex CLI to run with bypassed approvals/sandboxing.
CODEX_ALLOW_DANGEROUS=0

# Optional override. Usually auto-discovered from ~/.codex/config.toml.
CODEX_CLI_PATH=
